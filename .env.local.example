# =============================================
# 프론트엔드 환경변수 (.env.local 에 복사 후 실제 값으로 교체)
# =============================================

# Supabase — 대시보드 > Project Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# =============================================
# 절대 프론트엔드에 두면 안 되는 키 (참고용 주석)
# 아래 키들은 Supabase 대시보드 > Edge Functions > Environment Variables 에만 설정
# =============================================
# ANTHROPIC_API_KEY=sk-ant-api03-...          (Edge Functions 전용)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...       (Edge Functions 전용, Supabase 자동 주입)
